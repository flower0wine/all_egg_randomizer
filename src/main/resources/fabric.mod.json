{
	"schemaVersion": 1,
	"id": "alleggrandomizer",
	"version": "${version}",
	"name": "All Egg Randomizer",
	"description": "万物彩蛋 - 鸡蛋砸出随机物品",
	"authors": [
		"flowerwine",
		"任性"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
